# EmailJS configuration.
#
# These three IDs are PUBLIC by design — EmailJS ships them in the browser
# bundle, so committing them here is safe and keeps the CI build working with
# zero extra setup. The real protection against abuse is the "Allowed Origins"
# allow-list in your EmailJS dashboard (Account → Security), NOT hiding these.
VITE_EMAILJS_PUBLIC_KEY=1AkByoDhGNFhkKR8P
VITE_EMAILJS_SERVICE_ID=service_o1nb8bf
VITE_EMAILJS_TEMPLATE_ID=template_7x07rj7
